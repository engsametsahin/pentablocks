# Public site URL, used for canonical links and backend callbacks.
VITE_SITE_URL="https://playpentablocks.com"

# API base URL for browser calls.
VITE_API_BASE_URL="http://localhost:8787"

# Google OAuth client id for browser Google Sign-In button.
VITE_GOOGLE_CLIENT_ID=""

# Optional analytics endpoint. If set, events are sent via sendBeacon/fetch.
# Example: https://api.playpentablocks.com/events
VITE_ANALYTICS_ENDPOINT=""

# Optional error reporting endpoint for client runtime errors.
# Example: https://api.playpentablocks.com/client-errors
VITE_ERROR_REPORT_ENDPOINT=""

# Optional debug switch for analytics logs in browser console.
VITE_ANALYTICS_DEBUG="false"

# API server config (Express + PostgreSQL).
API_PORT="8787"
APP_ORIGIN="http://localhost:3020"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pentablocks"

# Google OAuth client id used by backend token verifier.
# Keep this equal to VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=""
